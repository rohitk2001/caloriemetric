</style>

<script>
  // ─────────────────────────────────────
  // CONSTANTS
  // ─────────────────────────────────────
  const BADGES_CONFIG = [
    { id: 'week_warrior',   emoji: '🥉', name: 'Week Warrior',   req: '7-day streak',   days: 7 },
    { id: 'monthly_master', emoji: '🥈', name: 'Monthly Master', req: '30-day streak',  days: 30 },
    { id: 'century_club',   emoji: '🥇', name: 'Century Club',   req: '100-day streak', days: 100 },
  ];
  const GOAL_LABELS = { lose: 'Lose Weight', maintain: 'Maintain Weight', gain: 'Gain Weight' };
  const MEAL_SECTIONS = [
    { id: 'breakfast', label: '🌅 Breakfast' },
    { id: 'lunch',     label: '☀️ Lunch' },
    { id: 'snacks',    label: '🍎 Snacks' },
    { id: 'dinner',    label: '🌙 Dinner' },
    { id: 'misc',      label: '🍵 Miscellaneous' },
  ];
  const PLATE_MEALS = [
    { id: 'breakfast', label: '🌅 Breakfast' },
    { id: 'lunch',     label: '☀️ Lunch' },
    { id: 'dinner',    label: '🌙 Dinner' },
  ];
  const DEFAULT_SECTIONS = [
    { name: 'Veggies & Fruits', emoji: '🥦', pct: 50, color: '#10b981' },
    { name: 'Grains & Carbs',   emoji: '🍚', pct: 25, color: '#f59e0b' },
    { name: 'Protein',          emoji: '🍗', pct: 25, color: '#f97316' },
  ];

  // ─────────────────────────────────────
  // UTILITIES
  // ─────────────────────────────────────
  function todayStr() { return new Date().toISOString().split('T')[0]; }
  function formatDate(d) { return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' }); }
  function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function getWeekKey() {
    const d = new Date();
    const day = d.getDay();
    const diff = day === 0 ? -6 : 1 - day;
    const monday = new Date(d);
    monday.setDate(d.getDate() + diff);
    return monday.toISOString().split('T')[0];
  }
  function isMonday() { return new Date().getDay() === 1; }

  // ─────────────────────────────────────
  // STORAGE HELPERS
  // ─────────────────────────────────────
  function getSettings() {
    try { return { waterGoal: 8, flexAllowance: 2, ...JSON.parse(localStorage.getItem('cm_settings') || '{}') }; }
    catch { return { waterGoal: 8, flexAllowance: 2 }; }
  }

  // cm_logs — detailed mode
  function getLogs() { try { return JSON.parse(localStorage.getItem('cm_logs') || '{}'); } catch { return {}; } }
  function saveLogs(l) { try { localStorage.setItem('cm_logs', JSON.stringify(l)); } catch {} }
  function getTodayMeals() { const day = getLogs()[todayStr()]; return Array.isArray(day) ? day : []; }
  function saveTodayMeals(meals) { const logs = getLogs(); logs[todayStr()] = meals; saveLogs(logs); }
  function totalForDay(meals) { if (!Array.isArray(meals)) return 0; return meals.reduce((s, m) => s + (m.calories || 0), 0); }

  // cm_plates — simple mode
  function getPlates() { try { return JSON.parse(localStorage.getItem('cm_plates') || '{}'); } catch { return {}; } }
  function savePlates(p) { try { localStorage.setItem('cm_plates', JSON.stringify(p)); } catch {} }
  function getTodayPlates() { return getPlates()[todayStr()] || { breakfast: null, lunch: null, dinner: null }; }
  function saveTodayPlates(plates) { const all = getPlates(); all[todayStr()] = plates; savePlates(all); }

  // cm_habits — simple mode
  function getHabits() { try { return JSON.parse(localStorage.getItem('cm_habits') || '{}'); } catch { return {}; } }
  function saveHabits(h) { try { localStorage.setItem('cm_habits', JSON.stringify(h)); } catch {} }
  function getTodayHabits() { return getHabits()[todayStr()] || { water: 0, sleep: null, activity: null, mood: null, energy: null, fruits: false, salad: false, nuts: false, flexBonusGiven: false }; }
  function saveTodayHabits(habits) { const all = getHabits(); all[todayStr()] = habits; saveHabits(all); }

  // cm_flex_plates — used = treat plates this week, earned = bonus from activity (0–2)
  function getFlexPlates() {
    const weekKey = getWeekKey();
    let flex;
    try { flex = JSON.parse(localStorage.getItem('cm_flex_plates') || 'null'); } catch { flex = null; }
    if (!flex || flex.week !== weekKey) {
      flex = { week: weekKey, used: 0, earned: 0 };
      try { localStorage.setItem('cm_flex_plates', JSON.stringify(flex)); } catch {}
    }
    return flex;
  }
  function saveFlexPlates(f) { try { localStorage.setItem('cm_flex_plates', JSON.stringify(f)); } catch {} }

  // cm_weight_log
  function getWeightLog() { try { return JSON.parse(localStorage.getItem('cm_weight_log') || '[]'); } catch { return []; } }
  function saveWeightLog(w) { try { localStorage.setItem('cm_weight_log', JSON.stringify(w)); } catch {} }

  // cm_streak / cm_badges
  function getStreak() {
    try { return JSON.parse(localStorage.getItem('cm_streak') || '{"currentStreak":0,"lastLoggedDate":"","longestStreak":0}'); }
    catch { return { currentStreak: 0, lastLoggedDate: '', longestStreak: 0 }; }
  }
  function getBadges() { try { return JSON.parse(localStorage.getItem('cm_badges') || '[]'); } catch { return []; } }

  // ─────────────────────────────────────
  // STREAK + BADGES
  // ─────────────────────────────────────
  function computeAndSaveStreak(isStreakDay) {
    const today = todayStr();
    let streak = getStreak();
    if (isStreakDay) {
      const yesterday = new Date(); yesterday.setDate(yesterday.getDate() - 1);
      const yStr = yesterday.toISOString().split('T')[0];
      if (streak.lastLoggedDate === yStr) { streak.currentStreak += 1; streak.lastLoggedDate = today; }
      else if (streak.lastLoggedDate !== today) { streak.currentStreak = 1; streak.lastLoggedDate = today; }
      if (streak.currentStreak > streak.longestStreak) streak.longestStreak = streak.currentStreak;
    } else if (streak.lastLoggedDate && streak.lastLoggedDate !== today) {
      const diff = Math.floor((Date.now() - new Date(streak.lastLoggedDate + 'T00:00:00').getTime()) / 86400000);
      if (diff > 1) streak.currentStreak = 0;
    }
    try { localStorage.setItem('cm_streak', JSON.stringify(streak)); } catch {}
    return streak;
  }

  function updateDetailedStreak(target) {
    const meals = getTodayMeals();
    const total = totalForDay(meals);
    return computeAndSaveStreak(meals.length > 0 && total <= target);
  }

  function updateSimpleStreak() {
    const plates = getTodayPlates();
    const habits = getTodayHabits();
    const allPlates = !!(plates.breakfast && plates.lunch && plates.dinner);
    const allHabits = habits.sleep !== null && (habits.water || 0) > 0 && habits.activity !== null;
    return computeAndSaveStreak(allPlates && allHabits);
  }

  function awardBadges(streak) {
    const badges = getBadges();
    BADGES_CONFIG.forEach(b => { if (streak.longestStreak >= b.days && !badges.includes(b.id)) badges.push(b.id); });
    try { localStorage.setItem('cm_badges', JSON.stringify(badges)); } catch {}
    return badges;
  }

  function renderBadges(containerId) {
    const el = document.getElementById(containerId);
    if (!el) return;
    const earned = getBadges();
    el.innerHTML = BADGES_CONFIG.map(b => `
      <div class="badge-item ${earned.includes(b.id) ? 'earned' : 'locked'}">
        <span class="badge-emoji">${earned.includes(b.id) ? b.emoji : '🔒'}</span>
        <div class="badge-info">
          <div class="badge-name">${b.name}</div>
          <div class="badge-req">${b.req}</div>
        </div>
      </div>
    `).join('');
  }

  function updateStreakMini(streak) {
    const el = document.getElementById('mini-streak-count');
    if (el) el.textContent = String(streak.currentStreak);
  }

  function refreshStreakAndBadges(mode) {
    const target = parseInt(localStorage.getItem('cm_target') || localStorage.getItem('cm_tdee') || '0');
    const streak = mode === 'simple' ? updateSimpleStreak() : updateDetailedStreak(target);
    awardBadges(streak);
    updateStreakMini(streak);
    renderBadges(mode === 'simple' ? 'badges-grid-simple' : 'badges-grid-detailed');
  }

  // ─────────────────────────────────────
  // PLATE CIRCLE — STATE
  // ─────────────────────────────────────
  let plateSections = DEFAULT_SECTIONS.map(s => ({ ...s })); // active sections on the circle
  let removedSections = []; // sections the user removed from the circle
  let pendingRemoveSection = null; // index in plateSections awaiting removal confirmation
  let currentPlateMeal = null;
  let verdictConfirmed = null; // null | 'healthy' | 'treat'

  // ─────────────────────────────────────
  // PLATE CIRCLE — VERDICT LOGIC
  // ─────────────────────────────────────
  function getSuggestedVerdict() {
    // 2-section rule: if either section dominates beyond 65%
    if (plateSections.length === 2) {
      return Math.max(...plateSections.map(s => s.pct)) > 65 ? 'treat' : 'healthy';
    }
    const grainsS = plateSections.find(s => s.name === 'Grains & Carbs');
    const grains = grainsS ? grainsS.pct : 0;
    return grains > 50 ? 'treat' : 'healthy';
  }

  function getNudgeTips() {
    const tips = [];
    const veggiesS = plateSections.find(s => s.name === 'Veggies & Fruits');
    const proteinS = plateSections.find(s => s.name === 'Protein');
    const veggiesPct = veggiesS ? veggiesS.pct : 0;
    const proteinPct = proteinS ? proteinS.pct : 0;
    if (veggiesPct < 20) tips.push("💡 Try adding some colour to your next plate 🥦 Even a small salad counts!");
    if (proteinPct < 10) tips.push("💡 Try adding a protein source next time 💪 Eggs, beans or chicken work great");
    return tips;
  }

  function renderVerdictUI() {
    const row = document.getElementById('plate-verdict-row');
    const logBtn = document.getElementById('log-plate-btn');
    if (!row) return;

    if (verdictConfirmed === null) {
      const suggested = getSuggestedVerdict();
      const nudges = getNudgeTips();
      const nudgeHtml = nudges.map(t => `<p class="verdict-nudge-tip">${t}</p>`).join('');

      if (suggested === 'treat') {
        row.innerHTML = `
          <p class="verdict-suggest"><strong>This plate is quite carb-heavy 🍚</strong><br>Harvard recommends grains as just ¼ of your plate for best results.<br><br>Was this a treat meal?</p>
          <div class="verdict-confirm-btns">
            <button class="habit-pill" data-confirm="healthy">🟢 Actually Healthy</button>
            <button class="habit-pill active" data-confirm="treat">🔵 Yes, Treat</button>
          </div>
          ${nudgeHtml}`;
      } else {
        row.innerHTML = `
          <p class="verdict-suggest"><strong>This looks like a Healthy Plate 🟢</strong><br>Grains are well balanced.<br><br>Does that sound right?</p>
          <div class="verdict-confirm-btns">
            <button class="habit-pill active" data-confirm="healthy">✅ Yes, Healthy</button>
            <button class="habit-pill" data-confirm="treat">🔵 Actually a Treat</button>
          </div>
          ${nudgeHtml}`;
      }
      if (logBtn) logBtn.classList.add('hidden');

      row.querySelectorAll('[data-confirm]').forEach(btn => {
        btn.addEventListener('click', () => {
          verdictConfirmed = (btn as HTMLElement).dataset.confirm;
          renderVerdictUI();
        });
      });
    } else {
      const label = verdictConfirmed === 'treat' ? 'Treat Plate 🔵' : 'Healthy Plate 🟢';
      row.innerHTML = `
        <div class="verdict-confirmed-row">
          <span class="verdict-confirmed-label">${label}</span>
          <button class="logger-cancel" id="change-verdict-btn">Change</button>
        </div>`;
      document.getElementById('change-verdict-btn')?.addEventListener('click', () => {
        verdictConfirmed = null;
        renderVerdictUI();
      });
      if (logBtn) logBtn.classList.remove('hidden');
    }
  }

  // ─────────────────────────────────────
  // PLATE CIRCLE — SVG RENDERING
  // ─────────────────────────────────────
  function polarToXY(angleDeg, r) {
    const rad = (angleDeg - 90) * Math.PI / 180;
    return { x: +(100 + r * Math.cos(rad)).toFixed(2), y: +(100 + r * Math.sin(rad)).toFixed(2) };
  }

  function donutArcPath(startPct, endPct, outerR, innerR) {
    const s = startPct * 3.6, e = endPct * 3.6;
    const os = polarToXY(s, outerR), oe = polarToXY(e, outerR);
    const ie = polarToXY(e, innerR), is_ = polarToXY(s, innerR);
    const lg = (endPct - startPct) > 50 ? 1 : 0;
    return `M ${os.x} ${os.y} A ${outerR} ${outerR} 0 ${lg} 1 ${oe.x} ${oe.y} L ${ie.x} ${ie.y} A ${innerR} ${innerR} 0 ${lg} 0 ${is_.x} ${is_.y} Z`;
  }

  function renderPlateSVG() {
    const svg = document.getElementById('plate-svg');
    if (!svg) return;
    const outerR = 82, innerR = 38;
    let cum = 0, paths = '', labels = '', handles = '';
    const boundaries = [];

    for (let i = 0; i < plateSections.length; i++) {
      const s = plateSections[i];
      const start = cum, end = cum + s.pct;
      if (s.pct > 0) {
        paths += `<path d="${donutArcPath(start, end, outerR, innerR)}" fill="${s.color}" opacity="0.88" stroke="var(--color-canvas)" stroke-width="1.5" />`;
      }
      if (s.pct > 7) {
        const mid = polarToXY(((start + end) / 2) * 3.6, (outerR + innerR) / 2);
        labels += `<text x="${mid.x}" y="${mid.y}" text-anchor="middle" dominant-baseline="middle" font-size="15" style="pointer-events:none;user-select:none">${s.emoji}</text>`;
      }
      cum = end;
      if (i < plateSections.length - 1) boundaries.push(cum);
    }

    for (let i = 0; i < boundaries.length; i++) {
      const pos = polarToXY(boundaries[i] * 3.6, outerR);
      handles += `<circle class="ph" data-i="${i}" cx="${pos.x}" cy="${pos.y}" r="20" fill="rgba(0,0,0,0)" stroke="none" pointer-events="all" style="cursor:grab;touch-action:none" /><circle class="pv" cx="${pos.x}" cy="${pos.y}" r="9" fill="white" stroke="#94a3b8" stroke-width="2.5" style="pointer-events:none;touch-action:none" />`;
    }

    // Harvard target boundary markers (dotted lines at ideal 50% and 75% positions)
    const HARVARD_BOUNDS = [50, 75];
    let targetMarkers = '';
    HARVARD_BOUNDS.forEach(t => {
      const innerPt = polarToXY(t * 3.6, innerR + 2);
      const outerPt = polarToXY(t * 3.6, outerR + 5);
      targetMarkers += `<line x1="${innerPt.x}" y1="${innerPt.y}" x2="${outerPt.x}" y2="${outerPt.y}" stroke="rgba(255,255,255,0.75)" stroke-width="1.5" stroke-dasharray="3,2" pointer-events="none" />`;
    });

    svg.innerHTML = paths + labels + targetMarkers + handles;
    svg.querySelectorAll('.ph').forEach(h => {
      h.addEventListener('mousedown', startPlateDrag);
      h.addEventListener('touchstart', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const handleIdx = parseInt((e.currentTarget as HTMLElement).dataset.i);
        const svgEl = document.getElementById('plate-svg');

        function touchMove(ev) {
          ev.preventDefault();
          ev.stopPropagation();
          const rect = svgEl.getBoundingClientRect();
          const touch = ev.touches[0];
          const svgX = (touch.clientX - rect.left) / rect.width * 200;
          const svgY = (touch.clientY - rect.top) / rect.height * 200;
          let angle = Math.atan2(svgY - 100, svgX - 100) * 180 / Math.PI + 90;
          if (angle < 0) angle += 360;
          if (angle >= 360) angle -= 360;
          let newPct = angle / 3.6;
          let cum2 = 0;
          const cumPcts = [];
          for (let j = 0; j < plateSections.length - 1; j++) {
            cum2 += plateSections[j].pct;
            cumPcts.push(cum2);
          }
          const minSize = 5;
          const prevBound = handleIdx === 0 ? 0 : cumPcts[handleIdx - 1];
          const nextBound = handleIdx === cumPcts.length - 1 ? 100 : cumPcts[handleIdx + 1];
          newPct = Math.max(prevBound + minSize, Math.min(nextBound - minSize, newPct));
          cumPcts[handleIdx] = newPct;
          plateSections[0].pct = cumPcts[0];
          for (let j = 1; j < plateSections.length - 1; j++) {
            plateSections[j].pct = cumPcts[j] - cumPcts[j - 1];
          }
          plateSections[plateSections.length - 1].pct = 100 - cumPcts[cumPcts.length - 1];
          renderPlateSVG();
        }

        function touchEnd(ev) {
          ev.preventDefault();
          h.removeEventListener('touchmove', touchMove);
          h.removeEventListener('touchend', touchEnd);
        }

        h.addEventListener('touchmove', touchMove, { passive: false });
        h.addEventListener('touchend', touchEnd, { passive: false });
      }, { passive: false });
    });

    // Glow: Grains & Carbs > 50% → warning orange, else green
    const grainsGlowS = plateSections.find(s => s.name === 'Grains & Carbs');
    const grainsPct = grainsGlowS ? grainsGlowS.pct : 0;
    const isTreatHint = grainsPct > 50;
    const cont = document.getElementById('plate-circle-container');
    if (cont) cont.className = 'plate-circle-container ' + (isTreatHint ? 'glow-treat' : 'glow-healthy');

    // Section labels with × remove button (hidden when only 2 sections remain)
    const canRemove = plateSections.length > 2;
    const ll = document.getElementById('plate-section-labels');
    if (ll) {
      ll.innerHTML = plateSections.map((s, i) => `
        <div class="sl-row">
          <span class="sl-name">${s.emoji} ${s.name}</span>
          <div style="display:flex;align-items:center;gap:6px">
            <span class="sl-pct" style="color:${s.color}">${Math.round(s.pct)}%</span>
            ${canRemove ? `<button class="sl-remove-btn" data-remove-idx="${i}" title="Remove ${s.name}">×</button>` : ''}
          </div>
        </div>`).join('');

      ll.querySelectorAll('.sl-remove-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt((btn as HTMLElement).dataset.removeIdx);
          pendingRemoveSection = pendingRemoveSection === idx ? null : idx;
          renderConfirmArea();
        });
      });
    }

    // Removed section re-add pills
    const ra = document.getElementById('removed-sections-area');
    if (ra) {
      if (removedSections.length > 0) {
        ra.innerHTML = removedSections.map((s, i) =>
          `<button class="removed-pill" data-readd-idx="${i}">+ ${s.emoji} ${s.name}</button>`
        ).join('');
        ra.querySelectorAll('.removed-pill').forEach(btn => {
          btn.addEventListener('click', () => reAddSection(parseInt((btn as HTMLElement).dataset.readdIdx)));
        });
      } else {
        ra.innerHTML = '';
      }
    }

    renderConfirmArea();
    if (verdictConfirmed === null) renderVerdictUI();
  }

  function renderConfirmArea() {
    const ca = document.getElementById('remove-confirm-area');
    if (!ca) return;
    if (pendingRemoveSection === null || pendingRemoveSection >= plateSections.length) {
      ca.innerHTML = ''; return;
    }
    const s = plateSections[pendingRemoveSection];
    ca.innerHTML = `
      <div class="remove-confirm-box">
        <span class="remove-confirm-label">Remove ${s.emoji} ${s.name} from this plate?</span>
        <button class="btn-accent btn-sm" id="confirm-remove-btn">Remove</button>
        <button class="btn-secondary btn-sm" id="cancel-remove-btn">Keep</button>
      </div>`;
    document.getElementById('confirm-remove-btn')?.addEventListener('click', () => {
      const idx = pendingRemoveSection;
      pendingRemoveSection = null;
      removeSection(idx);
    });
    document.getElementById('cancel-remove-btn')?.addEventListener('click', () => {
      pendingRemoveSection = null;
      renderConfirmArea();
    });
  }

  function removeSection(idx) {
    const removed = plateSections.splice(idx, 1)[0];
    removedSections.push(removed);
    // Redistribute removed section's % proportionally among the remaining active sections
    const totalRem = plateSections.reduce((s, sec) => s + sec.pct, 0);
    if (totalRem > 0) {
      const bonus = removed.pct;
      plateSections.forEach(s => { s.pct += bonus * (s.pct / totalRem); });
    } else {
      plateSections.forEach(s => { s.pct = 100 / plateSections.length; });
    }
    // Normalize to sum exactly 100
    const sum = plateSections.reduce((s, sec) => s + sec.pct, 0);
    plateSections.forEach(s => { s.pct = s.pct * 100 / sum; });
    verdictConfirmed = null;
    renderPlateSVG();
    renderVerdictUI();
  }

  function reAddSection(removedIdx) {
    const section = removedSections.splice(removedIdx, 1)[0];
    // Give the re-added section an equal share, shrink existing proportionally
    const n = plateSections.length;
    plateSections.forEach(s => { s.pct = s.pct * n / (n + 1); });
    section.pct = 100 / (n + 1);
    plateSections.push(section);
    // Restore original order from DEFAULT_SECTIONS
    const order = DEFAULT_SECTIONS.map(d => d.name);
    plateSections.sort((a, b) => order.indexOf(a.name) - order.indexOf(b.name));
    verdictConfirmed = null;
    renderPlateSVG();
    renderVerdictUI();
  }

  // ─────────────────────────────────────
  // PLATE CIRCLE — DRAG
  // ─────────────────────────────────────
  function startPlateDrag(e) {
    e.preventDefault();
    e.stopPropagation();
    const handleIdx = parseInt((e.currentTarget as HTMLElement).dataset.i);
    const svg = document.getElementById('plate-svg');

    function move(ev) {
      ev.preventDefault();
      const rect = svg.getBoundingClientRect();
      const cx = ev.touches ? ev.touches[0].clientX : ev.clientX;
      const cy = ev.touches ? ev.touches[0].clientY : ev.clientY;
      const svgX = (cx - rect.left) / rect.width * 200;
      const svgY = (cy - rect.top) / rect.height * 200;
      let angle = Math.atan2(svgY - 100, svgX - 100) * 180 / Math.PI + 90;
      if (angle < 0) angle += 360;
      if (angle >= 360) angle -= 360;
      let newPct = angle / 3.6;

      // Build cumulative boundaries array
      let cum2 = 0;
      const cumPcts = [];
      for (let j = 0; j < plateSections.length - 1; j++) {
        cum2 += plateSections[j].pct;
        cumPcts.push(cum2);
      }

      // Clamp: min 5% per active section — sections are removed explicitly via × button
      const minSize = 5;
      const prevBound = handleIdx === 0 ? 0 : cumPcts[handleIdx - 1];
      const nextBound = handleIdx === cumPcts.length - 1 ? 100 : cumPcts[handleIdx + 1];
      newPct = Math.max(prevBound + minSize, Math.min(nextBound - minSize, newPct));
      cumPcts[handleIdx] = newPct;

      // Recompute section percentages from cumulative boundaries
      plateSections[0].pct = cumPcts[0];
      for (let j = 1; j < plateSections.length - 1; j++) {
        plateSections[j].pct = cumPcts[j] - cumPcts[j - 1];
      }
      plateSections[plateSections.length - 1].pct = 100 - cumPcts[cumPcts.length - 1];

      renderPlateSVG();
    }

    function end() {
      document.removeEventListener('mousemove', move);
      document.removeEventListener('mouseup', end);
      document.removeEventListener('touchmove', move);
      document.removeEventListener('touchend', end);
    }

    document.addEventListener('mousemove', move);
    document.addEventListener('mouseup', end);
    document.addEventListener('touchmove', move, { passive: false });
    document.addEventListener('touchend', end);
  }

  // ─────────────────────────────────────
  // SIMPLE MODE — PLATES
  // ─────────────────────────────────────
  function openPlateLogger(meal) {
    currentPlateMeal = meal;
    if (!localStorage.getItem('cm_onboarded_plate')) {
      document.getElementById('plate-edu-overlay')?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      return;
    }
    openPlateLoggerPanel(meal);
  }

  function openPlateLoggerPanel(meal) {
    currentPlateMeal = meal;
    verdictConfirmed = null;

    const mealConf = PLATE_MEALS.find(m => m.id === meal);
    const title = document.getElementById('plate-logger-title');
    if (title) title.textContent = `Log ${mealConf ? mealConf.label : meal}`;

    // Load saved values if this plate was already logged
    const savedPlate = getTodayPlates()[meal];
    if (savedPlate) {
      if (savedPlate.sections && Array.isArray(savedPlate.sections)) {
        const knownNames = new Set(DEFAULT_SECTIONS.map(d => d.name));
        const compatible = savedPlate.sections.every(s => knownNames.has(s.name));
        if (compatible) {
          plateSections = savedPlate.sections.map(s => {
            const def = DEFAULT_SECTIONS.find(d => d.name === s.name);
            return { name: s.name, emoji: def?.emoji || s.emoji || '', color: def?.color || s.color || '#888', pct: s.pct };
          });
          removedSections = DEFAULT_SECTIONS
            .filter(d => !plateSections.find(s => s.name === d.name))
            .map(d => ({ ...d }));
        } else {
          // Old 4-section data — reset to new 3-section defaults
          plateSections = DEFAULT_SECTIONS.map(s => ({ ...s }));
          removedSections = [];
        }
      } else {
        // Legacy flat format
        plateSections = DEFAULT_SECTIONS.map(s => ({ ...s }));
        removedSections = [];
      }
      pendingRemoveSection = null;
      verdictConfirmed = savedPlate.verdict || null;
      const noteEl = document.getElementById('plate-note') as HTMLInputElement;
      if (noteEl) noteEl.value = savedPlate.note || '';
    } else {
      plateSections = DEFAULT_SECTIONS.map(s => ({ ...s }));
      removedSections = [];
      pendingRemoveSection = null;
      const noteEl = document.getElementById('plate-note') as HTMLInputElement;
      if (noteEl) noteEl.value = '';
    }

    const panel = document.getElementById('plate-logger-panel');
    if (panel) panel.classList.remove('hidden');
    renderPlateSVG();
    renderVerdictUI();
    panel?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function closePlateLogger() {
    currentPlateMeal = null;
    verdictConfirmed = null;
    removedSections = [];
    pendingRemoveSection = null;
    document.getElementById('plate-logger-panel')?.classList.add('hidden');
    document.getElementById('plate-info-panel')?.classList.add('hidden');
  }

  function logPlate() {
    if (!currentPlateMeal || !verdictConfirmed) return;
    const note = ((document.getElementById('plate-note') as HTMLInputElement)?.value || '').trim().slice(0, 200);
    const plateData = {
      sections: plateSections.map(s => ({ name: s.name, emoji: s.emoji, pct: Math.round(s.pct), color: s.color })),
      verdict: verdictConfirmed,
      note,
    };

    // Update flex plate used counter based on treat verdict transitions
    const plates = getTodayPlates();
    const prevVerdict = plates[currentPlateMeal]?.verdict || null;
    const nowTreat = verdictConfirmed === 'treat';
    const wasTreat = prevVerdict === 'treat';
    if (nowTreat && !wasTreat) {
      const flex = getFlexPlates(); flex.used++; saveFlexPlates(flex);
    } else if (!nowTreat && wasTreat) {
      const flex = getFlexPlates(); flex.used = Math.max(0, flex.used - 1); saveFlexPlates(flex);
    }

    plates[currentPlateMeal] = plateData;
    saveTodayPlates(plates);

    // Capture verdict + plate counts before closing (verdictConfirmed gets cleared)
    const finalVerdict = verdictConfirmed;
    const finalPlates = getTodayPlates();
    const healthyCount = PLATE_MEALS.filter(m => finalPlates[m.id]?.verdict === 'healthy').length;

    closePlateLogger();

    // Show 3-second motivational nudge
    let nudgeMsg = '';
    if (finalVerdict === 'healthy') {
      if (healthyCount === 3) nudgeMsg = "Amazing day! 🌟 You nailed the Harvard Plate today!";
      else if (healthyCount === 2) nudgeMsg = "Great job! 🟢 Keep it up for the rest of the day!";
      else nudgeMsg = "Good start! 🌱 Two more balanced plates to go!";
    } else {
      const flex = getFlexPlates();
      const available = (getSettings().flexAllowance || 2) + flex.earned - flex.used;
      nudgeMsg = available > 0
        ? "Enjoy it! 😊 You have flex plates left this week."
        : "That's okay! 💙 Every meal is a fresh start.";
    }
    const nudgeEl = document.getElementById('plate-log-nudge');
    if (nudgeEl && nudgeMsg) {
      nudgeEl.textContent = nudgeMsg;
      nudgeEl.classList.remove('hidden');
      setTimeout(() => nudgeEl.classList.add('hidden'), 3000);
    }

    refreshSimpleDashboard();
  }

  function deletePlate(meal) {
    const plates = getTodayPlates();
    // If deleted plate was a treat, decrement used
    if (plates[meal]?.verdict === 'treat') {
      const flex = getFlexPlates(); flex.used = Math.max(0, flex.used - 1); saveFlexPlates(flex);
    }
    plates[meal] = null;
    saveTodayPlates(plates);
    refreshSimpleDashboard();
  }

  // Day verdict: count treat plates
  function getDayVerdict() {
    const plates = getTodayPlates();
    const logged = PLATE_MEALS.filter(m => plates[m.id]).length;
    if (logged === 0) return null;
    const treats = PLATE_MEALS.filter(m => plates[m.id]?.verdict === 'treat').length;
    if (treats === 0) return { label: 'Great Day 🟢', cls: 'verdict-great' };
    if (treats === 1) return { label: 'Good Day 🟡', cls: 'verdict-good' };
    return { label: 'Keep Going 🔵', cls: 'verdict-keep' };
  }

  function renderPlateSlots() {
    const container = document.getElementById('plates-slots');
    if (!container) return;
    const plates = getTodayPlates();

    container.innerHTML = PLATE_MEALS.map(m => {
      const p = plates[m.id];
      if (p) {
        const isTreat = p.verdict === 'treat';
        const verdictLabel = isTreat ? 'Treat Plate 🔵' : 'Healthy Plate 🟢';
        const verdictCls = isTreat ? 'treat' : 'healthy';
        const sectionsText = p.sections
          ? p.sections.map(s => `${s.emoji}${s.pct}%`).join(' ')
          : `🥦${p.veggies || 0}% 🍗${p.protein || 0}% 🍚${p.carbs || 0}% 🥑${p.fats || 0}%`;
        return `<div class="plate-slot">
          <span class="plate-slot-label">${m.label}</span>
          <div class="plate-slot-logged">
            <span class="plate-slot-verdict ${verdictCls}">${verdictLabel}</span>
            <span class="plate-slot-sections">${sectionsText}</span>
            ${p.note ? `<span class="plate-slot-note">${escHtml(p.note)}</span>` : ''}
          </div>
          <div class="plate-slot-actions">
            <button class="plate-action-btn" data-edit="${m.id}">Edit</button>
            <button class="plate-action-btn danger" data-delete="${m.id}">Delete</button>
          </div>
        </div>`;
      }
      return `<div class="plate-slot">
        <span class="plate-slot-label">${m.label}</span>
        <div class="plate-slot-empty">
          <button class="btn-secondary btn-sm" data-log="${m.id}">+ Log Plate</button>
        </div>
      </div>`;
    }).join('');

    // Day verdict badge
    const v = getDayVerdict();
    const badge = document.getElementById('day-verdict-badge');
    if (badge) {
      badge.textContent = v ? v.label : '—';
      badge.className = 'day-verdict-badge' + (v ? ' ' + v.cls : '');
    }
    const si = document.getElementById('status-indicator');
    if (si) si.textContent = v ? v.label : '';
  }

  // ─────────────────────────────────────
  // SIMPLE MODE — HABITS
  // ─────────────────────────────────────
  function renderHabitsCard() {
    const el = document.getElementById('habits-content');
    if (!el) return;
    const habits = getTodayHabits();
    const waterGoal = getSettings().waterGoal || 8;
    const water = habits.water || 0;

    el.innerHTML = `
      <div class="habit-group">
        <span class="habit-group-label">💧 Water — ${water}/${waterGoal} glasses</span>
        <div class="water-counter-row">
          <button class="water-btn" id="water-minus-btn">−</button>
          <div style="display:flex;flex-wrap:wrap;gap:2px">${Array.from({length: waterGoal}, (_, i) =>
            `<span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:${i < water ? '#3b82f6' : 'var(--color-hairline)'}"></span>`
          ).join('')}</div>
          <button class="water-btn" id="water-plus-btn">+</button>
        </div>
      </div>
      <div class="habit-group">
        <span class="habit-group-label">😴 Sleep — Did you sleep 7+ hours?</span>
        <div class="habit-btn-row">
          <button class="habit-pill${habits.sleep === true ? ' active' : ''}" data-habit="sleep" data-val="true">Yes ✅</button>
          <button class="habit-pill${habits.sleep === false ? ' active' : ''}" data-habit="sleep" data-val="false">No ❌</button>
        </div>
      </div>
      <div class="habit-group">
        <span class="habit-group-label">🏃 Activity</span>
        <div class="habit-btn-row">
          <button class="habit-pill${habits.activity === 'steps' ? ' active' : ''}" data-habit="activity" data-val="steps">10k Steps 👟</button>
          <button class="habit-pill${habits.activity === 'gym' ? ' active' : ''}" data-habit="activity" data-val="gym">1hr Gym 🏋️</button>
          <button class="habit-pill${habits.activity === 'rest' ? ' active' : ''}" data-habit="activity" data-val="rest">Rest Day 😴</button>
        </div>
      </div>
      <div class="habit-group">
        <span class="habit-group-label">😊 Mood</span>
        <div class="mood-row">
          ${['😞','😐','🙂','😊','😄'].map((emoji, i) =>
            `<button class="mood-btn${habits.mood === i+1 ? ' active' : ''}" data-mood="${i+1}">${emoji}</button>`
          ).join('')}
        </div>
      </div>
      <div class="habit-group">
        <span class="habit-group-label">⚡ Energy</span>
        <div class="habit-btn-row">
          <button class="habit-pill${habits.energy === 'low' ? ' active' : ''}" data-habit="energy" data-val="low">Low</button>
          <button class="habit-pill${habits.energy === 'medium' ? ' active' : ''}" data-habit="energy" data-val="medium">Medium</button>
          <button class="habit-pill${habits.energy === 'high' ? ' active' : ''}" data-habit="energy" data-val="high">High</button>
        </div>
      </div>
    `;

    document.getElementById('water-plus-btn')?.addEventListener('click', () => {
      const h = getTodayHabits(); h.water = Math.min((h.water || 0) + 1, 20);
      saveTodayHabits(h); renderHabitsCard(); renderChecklistCard(); refreshStreakAndBadges('simple');
    });
    document.getElementById('water-minus-btn')?.addEventListener('click', () => {
      const h = getTodayHabits(); h.water = Math.max((h.water || 0) - 1, 0);
      saveTodayHabits(h); renderHabitsCard(); renderChecklistCard(); refreshStreakAndBadges('simple');
    });

    el.querySelectorAll('[data-habit]').forEach(btn => {
      btn.addEventListener('click', () => {
        const field = (btn as HTMLElement).dataset.habit;
        const rawVal = (btn as HTMLElement).dataset.val;
        const val = rawVal === 'true' ? true : rawVal === 'false' ? false : rawVal;
        const h = getTodayHabits();

        // Activity → earn +0.5 flex plate bonus (max 2 total earned bonus)
        if (field === 'activity') {
          const wasActive = h.activity === 'steps' || h.activity === 'gym';
          const isActive = val === 'steps' || val === 'gym';
          if (!wasActive && isActive && !h.flexBonusGiven) {
            h.flexBonusGiven = true;
            const flex = getFlexPlates();
            flex.earned = Math.min(2, flex.earned + 0.5);
            saveFlexPlates(flex);
          }
        }

        h[field] = val;
        saveTodayHabits(h);
        renderHabitsCard();
        renderFlexPlates();
        refreshStreakAndBadges('simple');
      });
    });

    el.querySelectorAll('[data-mood]').forEach(btn => {
      btn.addEventListener('click', () => {
        const h = getTodayHabits();
        h.mood = parseInt((btn as HTMLElement).dataset.mood);
        saveTodayHabits(h);
        renderHabitsCard();
      });
    });
  }

  function renderChecklistCard() {
    const el = document.getElementById('checklist-content');
    if (!el) return;
    const habits = getTodayHabits();
    const waterGoal = getSettings().waterGoal || 8;
    const waterEnough = (habits.water || 0) >= waterGoal;

    el.innerHTML = [
      { field: 'fruits', label: '🍎 Had fruits today?' },
      { field: 'salad',  label: '🥗 Had salad or veggies today?' },
      { field: 'nuts',   label: '🥜 Had nuts today?' },
    ].map(item => `
      <label class="checklist-item">
        <input type="checkbox" data-check="${item.field}" ${habits[item.field] ? 'checked' : ''} />
        <span>${item.label}</span>
      </label>
    `).join('') + `
      <div class="checklist-item auto-item">
        <input type="checkbox" ${waterEnough ? 'checked' : ''} disabled style="opacity:0.6" />
        <span class="checklist-label">💧 Drank enough water? ${waterEnough ? '(auto ✅)' : `(${habits.water || 0}/${waterGoal} glasses)`}</span>
      </div>`;

    el.querySelectorAll('[data-check]').forEach(cb => {
      cb.addEventListener('change', () => {
        const h = getTodayHabits();
        h[(cb as HTMLElement).dataset.check] = (cb as HTMLInputElement).checked;
        saveTodayHabits(h);
      });
    });
  }

  // ─────────────────────────────────────
  // SIMPLE MODE — FLEX PLATES
  // ─────────────────────────────────────
  function renderFlexPlates() {
    const el = document.getElementById('flex-plates-content');
    if (!el) return;
    const flex = getFlexPlates();
    const settings = getSettings();
    const baseAllowance = settings.flexAllowance || 2;
    const available = baseAllowance + flex.earned - flex.used;

    let statusCls, statusText;
    if (available > 0)      { statusCls = 'flex-status-green';  statusText = `${available} available`; }
    else if (available === 0) { statusCls = 'flex-status-yellow'; statusText = 'No flex plates left this week'; }
    else                     { statusCls = 'flex-status-red';    statusText = 'Over your flex plate limit'; }

    const totalSlots = Math.max(baseAllowance + flex.earned, flex.used);
    const icons = Array.from({ length: totalSlots }, (_, i) => {
      const cls = i < flex.used ? 'used' : i < baseAllowance + flex.earned ? 'avail' : '';
      return `<span class="flex-icon ${cls}">🔵</span>`;
    }).join('');

    el.innerHTML = `
      <p class="flex-plates-summary">
        Flex Plates this week: <strong>${flex.used} used</strong> / <strong>${flex.earned} earned</strong>
      </p>
      <span class="flex-status ${statusCls}">${statusText}</span>
      <div class="flex-plates-icons">${icons}</div>
      <p class="flex-plates-note">Base: ${baseAllowance} · +${flex.earned} from activity (max 2) · Resets Monday</p>
    `;
  }

  // ─────────────────────────────────────
  // SIMPLE MODE — WEIGHT LOG
  // ─────────────────────────────────────
  function shouldShowWeightCard() {
    const weekKey = getWeekKey();
    const log = getWeightLog();
    return isMonday() || !log.some(e => e.week === weekKey);
  }

  function renderWeightCard() {
    const card = document.getElementById('weight-card');
    const el = document.getElementById('weight-content');
    if (!card || !el) return;
    if (!shouldShowWeightCard()) { card.classList.add('hidden'); return; }
    card.classList.remove('hidden');

    const unitLabel = (localStorage.getItem('cm_units') || 'imperial') === 'metric' ? 'kg' : 'lbs';
    const log = getWeightLog();
    const recent = log.slice(-4);

    el.innerHTML = `
      <div class="weight-form">
        <input type="number" class="form-input weight-input" id="weight-input" placeholder="${unitLabel}" min="1" max="1000" step="0.1" />
        <span style="font-size:14px;color:var(--color-mute)">${unitLabel}</span>
        <button class="btn-accent btn-sm" id="log-weight-btn">Log Weight</button>
      </div>
      ${recent.length > 0 ? `
        <div class="weight-trend">
          <p class="eyebrow" style="margin-bottom:var(--space-xs)">Recent</p>
          ${recent.reverse().map((e, i, arr) => {
            const prev = arr[i + 1];
            const dir = !prev ? '—' : e.weight > prev.weight ? '↑' : e.weight < prev.weight ? '↓' : '→';
            return `<div class="weight-trend-row"><span>${e.week}</span><span>${e.weight} ${e.unit}</span><span class="weight-trend-dir">${dir}</span></div>`;
          }).join('')}
        </div>` : ''}`;

    document.getElementById('log-weight-btn')?.addEventListener('click', () => {
      const val = parseFloat((document.getElementById('weight-input') as HTMLInputElement).value);
      if (!val || val <= 0) return;
      const weekKey = getWeekKey();
      const wlog = getWeightLog().filter(e => e.week !== weekKey);
      wlog.push({ week: weekKey, weight: val, unit: unitLabel });
      saveWeightLog(wlog);
      renderWeightCard();
    });
  }

  // ─────────────────────────────────────
  // SIMPLE MODE — FULL REFRESH
  // ─────────────────────────────────────
  function refreshSimpleDashboard() {
    renderPlateSlots();
    renderFlexPlates();
    renderHabitsCard();
    renderChecklistCard();
    renderWeightCard();
    refreshStreakAndBadges('simple');
  }

  // ─────────────────────────────────────
  // DETAILED MODE — MEAL SECTIONS
  // ─────────────────────────────────────
  let openFormSection = null;

  function getTodayMealsBySection() {
    const meals = getTodayMeals();
    const bySection = {};
    MEAL_SECTIONS.forEach(s => { bySection[s.id] = []; });
    meals.forEach((m, idx) => {
      const sec = m.section || 'misc';
      if (!bySection[sec]) bySection[sec] = [];
      bySection[sec].push({ ...m, _idx: idx });
    });
    return bySection;
  }

  function renderMealSections() {
    const root = document.getElementById('meal-sections-root');
    if (!root) return;
    const bySection = getTodayMealsBySection();

    root.innerHTML = MEAL_SECTIONS.map(sec => {
      const items = bySection[sec.id] || [];
      const secTotal = items.reduce((s, m) => s + (m.calories || 0), 0);
      const isOpen = openFormSection === sec.id;

      return `<div class="det-meal-section" id="det-sec-${sec.id}">
        <div class="det-section-header">
          <span class="det-section-title">${sec.label}</span>
          <div class="det-section-meta">
            <span class="det-section-total${secTotal > 0 ? ' has-food' : ''}">${secTotal > 0 ? secTotal + ' kcal' : ''}</span>
            <button class="btn-accent btn-sm" data-open-form="${sec.id}">+ Add</button>
          </div>
        </div>
        <div class="det-meal-list">
          ${items.map(m => `
            <div class="det-meal-row">
              <span class="det-meal-name">${escHtml(m.name)}</span>
              ${(m.protein || m.carbs || m.fats) ? `<span class="det-meal-macros">P:${m.protein||0}g C:${m.carbs||0}g F:${m.fats||0}g</span>` : ''}
              <span class="det-meal-cal">${m.calories} kcal</span>
              <button class="det-meal-del" data-del-idx="${m._idx}" aria-label="Delete ${escHtml(m.name)}">×</button>
            </div>
          `).join('')}
        </div>
        ${isOpen ? `<div class="det-inline-form" id="form-${sec.id}">
          <div class="form-group"><label class="form-label" style="font-size:13px">Food name</label><input type="text" class="form-input" id="fn-${sec.id}" placeholder="e.g. Oatmeal" maxlength="200" /></div>
          <div class="form-group"><label class="form-label" style="font-size:13px">Calories <span style="color:var(--color-mute)">(required)</span></label><input type="number" class="form-input" id="fc-${sec.id}" placeholder="kcal" min="1" /></div>
          <div class="det-form-row">
            <div class="form-group"><label class="form-label" style="font-size:13px">Protein <span style="color:var(--color-mute)">(optional)</span></label><input type="number" class="form-input" id="fp-${sec.id}" placeholder="0g" min="0" /></div>
            <div class="form-group"><label class="form-label" style="font-size:13px">Carbs <span style="color:var(--color-mute)">(optional)</span></label><input type="number" class="form-input" id="fk-${sec.id}" placeholder="0g" min="0" /></div>
            <div class="form-group"><label class="form-label" style="font-size:13px">Fats <span style="color:var(--color-mute)">(optional)</span></label><input type="number" class="form-input" id="ff-${sec.id}" placeholder="0g" min="0" /></div>
          </div>
          <div class="det-form-actions">
            <button class="btn-accent btn-sm" data-add-meal="${sec.id}">Add</button>
            <button class="btn-secondary btn-sm" data-close-form="${sec.id}">Cancel</button>
          </div>
        </div>` : ''}
      </div>`;
    }).join('');

  }

  function updateDetailedCaloriesUI(target) {
    const meals = getTodayMeals();
    const consumed = totalForDay(meals);
    const pct = Math.min(100, Math.round((consumed / target) * 100));

    const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
    set('cal-consumed', consumed.toLocaleString());
    set('cal-goal', target.toLocaleString());
    set('cal-remaining', Math.max(0, target - consumed).toLocaleString());
    set('cal-percent-text', pct + '% of goal');

    const fill = document.getElementById('progress-fill');
    if (fill) { fill.style.width = pct + '%'; fill.className = 'progress-fill' + (consumed > target ? ' over' : consumed > target * 0.95 ? ' close' : ''); }
    document.getElementById('cal-progress')?.setAttribute('aria-valuenow', String(pct));

    const si = document.getElementById('status-indicator');
    if (si) {
      if (consumed <= target) { si.textContent = 'On Track ✅'; si.style.color = 'var(--color-accent-deep)'; }
      else if (consumed <= target + 50) { si.textContent = 'Almost There 🎯'; si.style.color = 'var(--color-warning)'; }
      else { si.textContent = 'Over Budget ⚠️'; si.style.color = 'var(--color-error)'; }
    }

    const totalP = meals.reduce((s, m) => s + (m.protein || 0), 0);
    const totalC = meals.reduce((s, m) => s + (m.carbs || 0), 0);
    const totalF = meals.reduce((s, m) => s + (m.fats || 0), 0);
    const hasMacros = totalP > 0 || totalC > 0 || totalF > 0;
    document.getElementById('macro-totals')?.classList.toggle('hidden', !hasMacros);
    if (hasMacros) { set('total-protein', totalP + 'g'); set('total-carbs', totalC + 'g'); set('total-fats', totalF + 'g'); }
  }

  function refreshDetailedDashboard() {
    const target = parseInt(localStorage.getItem('cm_target') || localStorage.getItem('cm_tdee') || '0');
    updateDetailedCaloriesUI(target);
    renderMealSections();
    refreshStreakAndBadges('detailed');
  }

  // ─────────────────────────────────────
  // INIT
  // ─────────────────────────────────────
  const tdeeRaw = localStorage.getItem('cm_tdee');
  if (!tdeeRaw) {
    document.getElementById('no-tdee-state')?.classList.remove('hidden');
  } else {
    document.getElementById('dashboard-main')?.classList.remove('hidden');
    document.getElementById('today-date').textContent = formatDate(todayStr());

    const mode = localStorage.getItem('cm_mode') || 'simple';
    const modeBadge = document.getElementById('mode-badge');
    if (modeBadge) modeBadge.textContent = mode === 'simple' ? 'Simple 🌱' : 'Detailed 📊';

    if (mode === 'simple') {
      document.getElementById('simple-dashboard')?.classList.remove('hidden');
      document.getElementById('goal-label').style.display = 'none';

      // Permanent event delegation for plate slots (works across re-renders)
      document.getElementById('plates-slots')?.addEventListener('click', e => {
        const logBtn  = (e.target as Element).closest('[data-log]');
        const editBtn = (e.target as Element).closest('[data-edit]');
        const delBtn  = (e.target as Element).closest('[data-delete]');
        if (logBtn)  openPlateLogger((logBtn as HTMLElement).dataset.log);
        else if (editBtn) openPlateLogger((editBtn as HTMLElement).dataset.edit);
        else if (delBtn)  deletePlate((delBtn as HTMLElement).dataset.delete);
      });

      document.getElementById('cancel-plate-btn')?.addEventListener('click', closePlateLogger);
      document.getElementById('log-plate-btn')?.addEventListener('click', logPlate);

      // Education modal CTA
      document.getElementById('plate-edu-cta')?.addEventListener('click', () => {
        try { localStorage.setItem('cm_onboarded_plate', 'true'); } catch {}
        document.getElementById('plate-edu-overlay')?.classList.add('hidden');
        document.body.style.overflow = '';
        if (currentPlateMeal) openPlateLoggerPanel(currentPlateMeal);
      });

      // Info panel toggle
      document.getElementById('plate-info-btn')?.addEventListener('click', () => {
        document.getElementById('plate-info-panel')?.classList.toggle('hidden');
      });

      refreshSimpleDashboard();
    } else {
      document.getElementById('detailed-dashboard')?.classList.remove('hidden');
      const goal = localStorage.getItem('cm_goal') || 'maintain';
      const target = parseInt(localStorage.getItem('cm_target') || tdeeRaw);
      document.getElementById('goal-label').textContent =
        `Goal: ${GOAL_LABELS[goal] || 'Maintain Weight'} — ${target.toLocaleString()} kcal/day`;

      // Permanent delegated listener — attached once, survives all innerHTML re-renders
      document.getElementById('meal-sections-root')?.addEventListener('click', e => {
        const openBtn  = (e.target as Element).closest('[data-open-form]');
        const addBtn   = (e.target as Element).closest('[data-add-meal]');
        const closeBtn = (e.target as Element).closest('[data-close-form]');
        const delBtn   = (e.target as Element).closest('[data-del-idx]');

        if (openBtn) {
          const id = (openBtn as HTMLElement).dataset.openForm;
          openFormSection = openFormSection === id ? null : id;
          renderMealSections();
          if (openFormSection) {
            document.getElementById('form-' + openFormSection)?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            setTimeout(() => (document.getElementById('fn-' + openFormSection) as HTMLInputElement)?.focus(), 100);
          }
        } else if (addBtn) {
          const secId = (addBtn as HTMLElement).dataset.addMeal;
          const name = ((document.getElementById('fn-' + secId) as HTMLInputElement)?.value || '').trim().slice(0, 200);
          const cal = parseInt((document.getElementById('fc-' + secId) as HTMLInputElement)?.value);
          if (!name || !cal || cal < 1) return;
          const meal: any = { name, calories: cal, section: secId };
          const pv = parseFloat((document.getElementById('fp-' + secId) as HTMLInputElement)?.value);
          const cv = parseFloat((document.getElementById('fk-' + secId) as HTMLInputElement)?.value);
          const fv = parseFloat((document.getElementById('ff-' + secId) as HTMLInputElement)?.value);
          if (!isNaN(pv)) meal.protein = pv;
          if (!isNaN(cv)) meal.carbs = cv;
          if (!isNaN(fv)) meal.fats = fv;
          const meals = getTodayMeals(); meals.push(meal); saveTodayMeals(meals);
          openFormSection = null;
          refreshDetailedDashboard();
        } else if (closeBtn) {
          openFormSection = null;
          renderMealSections();
        } else if (delBtn) {
          const idx = parseInt((delBtn as HTMLElement).dataset.delIdx);
          const meals = getTodayMeals(); meals.splice(idx, 1); saveTodayMeals(meals);
          refreshDetailedDashboard();
        }
      });

      refreshDetailedDashboard();
    }
  }
</script>
