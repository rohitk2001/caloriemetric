  // ── Cache lookup steps ──
  function cacheStepExact(normInput) {
    const cache = getCache();
    return resolveCache(cache, normInput);
  }

  function cacheStepQuantity(normInput) {
    const parts = normInput.split(/\s+/);
    const qty = parseFloat(parts[0]);
    if (!qty || isNaN(qty) || parts.length < 2) return null;
    const rest = parts.slice(1).join(' ');
    const cache = getCache();
    const hit = resolveCache(cache, rest);
    if (!hit) return null;
    return { hit, rest, qty, scaledCal: Math.round(hit.calories * qty) };
  }

  function cacheStepSplit(normInput) {
    const separators = /\s+(?:and|&|\+)\s+/;
    const parts = normInput.split(separators).map(p => p.trim()).filter(Boolean);
    if (parts.length < 2) return null;
    const cache = getCache();
    const found = [], missing = [];
    for (const part of parts) {
      let hit = resolveCache(cache, part);
      let qty = 1;
      if (!hit) {
        const subParts = part.split(/\s+/);
        const q = parseFloat(subParts[0]);
        if (!isNaN(q) && q > 0 && subParts.length > 1) {
          const rest = subParts.slice(1).join(' ');
          hit = resolveCache(cache, rest);
          if (hit) qty = q;
        }
      }
      if (hit) found.push({ part, hit, qty, scaledCal: Math.round(hit.calories * qty) });
      else missing.push(part);
    }
    return { found, missing, parts };
  }

  function cacheStepPartial(normInput) {
    const words = normInput.split(/\s+/).filter(w => !UNITS.includes(w) && isNaN(parseFloat(w)));
    if (!words.length) return null;
    const core = words.reduce((a, b) => b.length > a.length ? b : a, '');
    const cache = getCache();
    let best = null, bestTime = 0;
    for (const [k, v] of Object.entries(cache)) {
      if (typeof v === 'object' && k.includes(core) && v.cachedAt > bestTime) {
        best = v; bestTime = v.cachedAt;
      }
    }
    return best ? { hit: best, core } : null;
  }

  // ── Main lookup flow ──
  async function runLookup() {
    const inp = document.getElementById('logger-input');
    const rawQuery = inp?.value.trim();
    if (!rawQuery) return;

    const sanitized = sanitizeInput(rawQuery);
    if (!sanitized) {
      showInlineMessage('Please enter a food or meal description', 'error');
      return;
    }

    if (isOffensiveInput(sanitized)) {
      console.warn('[Filter] Blocked input:', sanitized);
      showInlineMessage('Please keep meal descriptions food-related 🥗', 'error');
      if (inp) { inp.value = ''; setTimeout(() => inp.focus(), 50); }
      return;
    }

    const statusEl = document.getElementById('logger-status');
    const resultsEl = document.getElementById('logger-results');
    const manualEl = document.getElementById('manual-entry');

    statusEl.classList.add('hidden');
    resultsEl.classList.add('hidden');
    manualEl.classList.add('hidden');

    const normInput = normalize(sanitized);

    // Step 1: exact
    const exact = cacheStepExact(normInput);
    if (exact) {
      showCacheResult(exact.name, exact.calories, 'cache');
      return;
    }

    // Step 2: quantity scaling
    const quantityMatch = cacheStepQuantity(normInput);
    if (quantityMatch) {
      showQuantitySuggestion(quantityMatch, normInput, sanitized);
      return;
    }

    // Step 3: multi-item split
    const splitMatch = cacheStepSplit(normInput);
    if (splitMatch && splitMatch.found.length > 0) {
      showSplitSuggestion(splitMatch, sanitized);
      return;
    }

    // Step 4: partial word
    const partial = cacheStepPartial(normInput);
    if (partial) {
      showPartialSuggestion(partial, sanitized);
      return;
    }

    // Step 5: API
    if (limitReached()) {
      showManual(sanitized, "You've used your AI lookups for today — no worries, just enter manually below!");
      return;
    }

    await callGroqAPI(sanitized, normInput);
  }

  function showInlineMessage(msg, type) {
    const el = document.getElementById('logger-status');
    el.innerHTML = `<span style="color:var(--color-${type === 'error' ? 'error' : 'mute'})">${escHtml(msg)}</span>`;
    el.classList.remove('hidden');
  }

  function showCacheResult(name, calories, source) {
    addMeal(name, calories);
  }

  function showQuantitySuggestion({ hit, qty, scaledCal }, normInput, originalQuery) {
    const resultsEl = document.getElementById('logger-results');
    resultsEl.innerHTML = `
      <div class="cache-suggestion">
        <p>${escHtml(hit.name)} × ${qty} — ${scaledCal} kcal?</p>
