  .det-meal-del { width: 22px; height: 22px; border-radius: var(--radius-xs); color: var(--color-mute); display: flex; align-items: center; justify-content: center; cursor: pointer; background: none; border: none; font-size: 16px; line-height: 1; transition: color 0.15s, background 0.15s; flex-shrink: 0; }
  .det-meal-del:hover { color: var(--color-error); background: var(--color-error-soft); }
