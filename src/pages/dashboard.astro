      await callGroqAPI(originalQuery, normalize(originalQuery));
    });
  }

  function showSplitSuggestion({ found, missing }, originalQuery) {
    const resultsEl = document.getElementById('logger-results');
    const totalFound = found.reduce((s, f) => s + f.scaledCal, 0);
    let html = `<div class="cache-suggestion"><p style="font-weight:600;margin-bottom:var(--space-xs)">Found in your history:</p>`;
    found.forEach(f => {
      const label = f.qty > 1 ? `${escHtml(f.hit.name)} ×${f.qty}` : escHtml(f.hit.name);
      html += `<p>✓ ${label} — ${f.scaledCal} kcal</p>`;
    });
    if (missing.length > 0) {
      html += `<p style="color:var(--color-mute);font-size:12px">Still searching: ${missing.map(escHtml).join(', ')}</p>`;
    }
    html += `<p style="font-weight:600;margin-top:var(--space-xs)">Total: ${totalFound} kcal</p>`;
    html += `<div class="suggestion-actions">`;
    if (missing.length === 0) {
      html += `<button class="btn-accent btn-sm" id="split-all">Add all</button>`;
      html += `<button class="btn-secondary btn-sm" id="split-pick">Pick individually</button>`;
    }
    html += `<button class="btn-secondary btn-sm" id="split-search">Search instead</button>`;
    html += `</div></div>`;
    resultsEl.innerHTML = html;
    resultsEl.classList.remove('hidden');

    document.getElementById('split-all')?.addEventListener('click', () => {
      found.forEach(f => {
        const name = f.qty > 1 ? `${f.hit.name} ×${f.qty}` : f.hit.name;
        addMeal(name, f.scaledCal);
      });
    });
    document.getElementById('split-pick')?.addEventListener('click', () => {
      resultsEl.innerHTML = found.map((f, i) => {
        const label = f.qty > 1 ? `${escHtml(f.hit.name)} ×${f.qty}` : escHtml(f.hit.name);
        return `
        <div class="cache-suggestion" style="margin-bottom:var(--space-xs)">
          <p>${label} — ${f.scaledCal} kcal</p>
          <div class="suggestion-actions">
            <button class="btn-accent btn-sm split-item-yes" data-idx="${i}">✓ Add</button>
            <button class="btn-secondary btn-sm split-item-no" data-idx="${i}">✗ Skip</button>
          </div>
        </div>`;
      }).join('');
      resultsEl.querySelectorAll('.split-item-yes').forEach(btn => {
        btn.addEventListener('click', () => {
          const f = found[parseInt(btn.dataset.idx)];
          const name = f.qty > 1 ? `${f.hit.name} ×${f.qty}` : f.hit.name;
          addMeal(name, f.scaledCal);
          btn.closest('.cache-suggestion').remove();
        });
      });
      resultsEl.querySelectorAll('.split-item-no').forEach(btn => {
        btn.addEventListener('click', () => btn.closest('.cache-suggestion').remove());
      });
    });
    document.getElementById('split-search')?.addEventListener('click', async () => {
      resultsEl.classList.add('hidden');
      if (limitReached()) { showManual(originalQuery, "You've used your AI lookups for today — no worries, just enter manually below!"); return; }
      await callGroqAPI(originalQuery, normalize(originalQuery));
    });
  }

  function showPartialSuggestion({ hit, core }, originalQuery) {
    const resultsEl = document.getElementById('logger-results');
    resultsEl.innerHTML = `
      <div class="cache-suggestion">
        <p>Did you mean <strong>${escHtml(hit.name)}</strong> (${hit.calories} kcal)?</p>
        <div class="suggestion-actions">
          <button class="btn-accent btn-sm" id="partial-yes">✓ Yes</button>
          <button class="btn-secondary btn-sm" id="partial-no">✗ No, search</button>
        </div>
      </div>
    `;
    resultsEl.classList.remove('hidden');
    document.getElementById('partial-yes').addEventListener('click', () => addMeal(hit.name, hit.calories));
    document.getElementById('partial-no').addEventListener('click', async () => {
      resultsEl.classList.add('hidden');
      if (limitReached()) { showManual(originalQuery, "You've used your AI lookups for today — no worries, just enter manually below!"); return; }
      await callGroqAPI(originalQuery, normalize(originalQuery));
    });
  }

  async function callGroqAPI(sanitizedQuery, normInput) {
    const statusEl = document.getElementById('logger-status');
    const resultsEl = document.getElementById('logger-results');
    statusEl.innerHTML = '<span class="spinner"></span> Estimating calories with AI…';
    statusEl.classList.remove('hidden');
    resultsEl.classList.add('hidden');

    try {
      const isLocalhost = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
      let res;
      if (isLocalhost) {
        res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${import.meta.env.PUBLIC_GROQ_API_KEY_DEV}`,
          },
          body: JSON.stringify({
            model: 'llama-3.1-8b-instant',
            messages: [
              { role: 'system', content: 'You are a nutrition expert. Only respond about food and calories. If asked about anything else, respond with: {"error": "not food"}. Always return valid JSON only. Format: {"foods": [{"name": "food name", "calories": number, "portion": "portion description"}], "total_calories": number, "confidence": "high/medium/low"}' },
              { role: 'user', content: `Food description: """${sanitizedQuery}"""` },
            ],
            temperature: 0.1,
            max_tokens: 500,
          }),
        });
      } else {
        res = await fetch('https://caloriemetric-api.rohitkhandelwal2001.workers.dev', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ input: sanitizedQuery }),
        });
      }

      if (res.status === 429) {
        statusEl.classList.add('hidden');
        showManual(sanitizedQuery, 'Our AI estimator is busy right now. Please try again in a minute or enter calories manually.');
        return;
      }
      if (!res.ok) { console.error('[meal-lookup]', res.status); throw new Error(); }

      const data = await res.json();
      const rawText = data?.choices?.[0]?.message?.content ?? '';
      const cleaned = rawText.replace(/^```(?:json)?\s*/i, '').replace(/\s*```$/i, '').trim();
      const parsed = JSON.parse(cleaned);

      if (parsed.error || !parsed.foods?.length) throw new Error('not food');

      incrementUsage();
      statusEl.classList.add('hidden');

      // Cache each individual ingredient for future partial/direct lookups
      parsed.foods.forEach(food => {
        const normFoodName = normalize(food.name);
        cacheSet(normFoodName, { name: food.name, calories: Math.round(food.calories) });
      });
      // Cache the original query with combined total so future exact lookups skip the API
      cacheSet(normInput, { name: sanitizedQuery, calories: Math.round(parsed.total_calories) });

      showResults(parsed, sanitizedQuery);
    } catch (err) {
      console.error('[Groq error]', err);
      statusEl.classList.add('hidden');
      showManual(sanitizedQuery, "Couldn't reach estimator. Enter manually:");
    }
  }

  function showResults(result, originalQuery) {
    const resultsEl = document.getElementById('logger-results');
    const lowConf = result.confidence === 'low';
    let currentTotal = Math.round(result.total_calories);

    const breakdownRows = result.foods.map(food => `
      <div style="display:flex;justify-content:space-between;font-size:13px;padding:3px 0;border-bottom:1px solid var(--color-hairline)">
        <span style="color:var(--color-body)">${escHtml(food.name)}</span>
        <span style="font-family:var(--font-mono);color:var(--color-mute)">${Math.round(food.calories)} kcal</span>
      </div>
    `).join('');

    resultsEl.innerHTML = `
      ${lowConf ? '<p class="confidence-warning">⚠️ Estimate may vary — use Edit total to adjust</p>' : ''}
      <div class="result-food-item" style="flex-direction:column;align-items:stretch;gap:var(--space-xs)">
        <p style="font-weight:600;font-size:14px;margin-bottom:var(--space-xxs)">${escHtml(originalQuery)}</p>
        <div>${breakdownRows}</div>
      </div>
      <div class="results-total-row">
        <span>Total: <strong class="results-total-num">${currentTotal} kcal</strong></span>
        <div style="display:flex;gap:var(--space-xs)">
          <button type="button" class="btn-secondary btn-sm" id="edit-total-btn">Edit total</button>
          <button type="button" class="btn-accent btn-sm" id="add-to-log-btn">Add to log</button>
        </div>
      </div>
      <input type="number" class="form-input hidden" id="total-cal-edit" value="${currentTotal}" min="0" style="margin-top:var(--space-xs)" />
    `;
    resultsEl.classList.remove('hidden');

    const totalNumEl = resultsEl.querySelector('.results-total-num');
    const editInput = document.getElementById('total-cal-edit');

    document.getElementById('edit-total-btn').addEventListener('click', () => {
      editInput.classList.toggle('hidden');
      if (!editInput.classList.contains('hidden')) { editInput.focus(); editInput.select(); }
    });

    editInput.addEventListener('input', () => {
      currentTotal = Math.round(parseFloat(editInput.value) || 0);
      totalNumEl.textContent = currentTotal + ' kcal';
    });

    document.getElementById('add-to-log-btn').addEventListener('click', () => {
      addMeal(originalQuery, currentTotal);
    });
  }

  function addMealSilent(name, calories) {
    const meals = getTodayMeals();
    meals.push({ name, calories });
    saveTodayMeals(meals);
  }

  function addMeal(name, calories) {
    addMealSilent(name, calories);
    closeLogger();
    refreshDashboard();
  }

  // ── Badges ──
  function renderBadges() {
    const earned = getBadges();
    document.getElementById('badges-grid').innerHTML = BADGES_CONFIG.map(b => `
      <div class="badge-item ${earned.includes(b.id) ? 'earned' : 'locked'}">
        <span class="badge-emoji">${earned.includes(b.id) ? b.emoji : '🔒'}</span>
        <div class="badge-info">
          <div class="badge-name">${b.name}</div>
          <div class="badge-req">${b.req}</div>
        </div>
      </div>
    `).join('');
  }

  function refreshDashboard() {
    const target = parseInt(localStorage.getItem('cm_target') || localStorage.getItem('cm_tdee') || '0');
    updateCaloriesUI(target);
    renderMeals();
    const streak = updateStreak(target);
    awardBadges(streak);
    renderBadges();
    document.getElementById('mini-streak-count').textContent = String(streak.currentStreak);
  }

  // ── Init ──
  const tdeeRaw = localStorage.getItem('cm_tdee');
  if (!tdeeRaw) {
    document.getElementById('no-tdee-state').classList.remove('hidden');
  } else {
    document.getElementById('dashboard-main').classList.remove('hidden');
    document.getElementById('today-date').textContent = formatDate(todayStr());
    const goal = localStorage.getItem('cm_goal') || 'maintain';
    const target = parseInt(localStorage.getItem('cm_target') || tdeeRaw);
    document.getElementById('goal-label').textContent =
      `Goal: ${GOAL_LABELS[goal] || 'Maintain Weight'} — ${target.toLocaleString()} kcal/day`;
    refreshDashboard();

    const prefill = localStorage.getItem('cm_prefill_meal');
    if (prefill) {
      localStorage.removeItem('cm_prefill_meal');
      try { const { name, calories } = JSON.parse(prefill); if (name && calories > 0) addMeal(name, calories); } catch {}
    }
  }
</script>
