---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Dashboard — CalorieMetric"
  description="Track your daily habits, view your streak, and stay on your goal with CalorieMetric."
>
  <section class="dashboard-page">
    <div class="container">

      <!-- No setup state -->
      <div id="no-tdee-state" class="no-tdee-state hidden">
        <div class="no-tdee-card card-lg">
          <div class="no-tdee-icon">📊</div>
          <h1 class="section-heading" style="margin-top:var(--space-md)">Set up your profile first.</h1>
          <p class="text-body" style="margin-top:var(--space-sm);max-width:400px">Calculate your maintenance calories and choose a tracking mode to unlock the dashboard.</p>
          <a href="/calculator" class="btn-primary" style="margin-top:var(--space-xl)">Get Started</a>
        </div>
      </div>

      <!-- Main dashboard -->
      <div id="dashboard-main" class="hidden">

        <!-- Top row (shared between modes) -->
        <div class="dashboard-top-row">
          <div class="date-block">
            <div class="date-mode-row">
              <p id="today-date" class="today-date"></p>
              <span id="mode-badge" class="mode-badge"></span>
            </div>
            <p id="goal-label" class="goal-label"></p>
            <p id="status-indicator" class="status-indicator"></p>
          </div>
          <a href="/streaks" class="streak-mini card">
            <span class="streak-fire">🔥</span>
            <div class="streak-mini-text">
              <span id="mini-streak-count" class="mini-streak-count">0</span>
              <span class="mini-streak-label">day streak</span>
            </div>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--color-mute);flex-shrink:0"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </a>
        </div>

        <!-- ═══ SIMPLE DASHBOARD ═══ -->
        <div id="simple-dashboard" class="hidden">

          <!-- Today's Plates -->
          <div class="card-lg plates-card" id="plates-card">
            <div class="plates-card-header">
              <h2 class="col-heading">Today's Plates</h2>
              <span id="day-verdict-badge" class="day-verdict-badge"></span>
            </div>
            <div class="plates-slots" id="plates-slots"></div>
            <div class="plate-log-nudge hidden" id="plate-log-nudge"></div>

            <!-- Shared Plate Logger Panel -->
            <div class="plate-logger-panel hidden" id="plate-logger-panel">
              <div class="divider" style="margin:var(--space-lg) 0"></div>
              <div class="plate-logger-header">
                <h3 id="plate-logger-title" class="col-heading"></h3>
                <div class="plate-logger-header-right">
                  <button class="plate-info-btn" id="plate-info-btn" aria-label="About the Harvard Plate">ℹ️</button>
                  <button class="logger-cancel" id="cancel-plate-btn">Cancel</button>
                </div>
              </div>
              <div class="plate-circle-wrap">
                <div class="plate-circle-container" id="plate-circle-container">
                  <svg id="plate-svg" viewBox="0 0 200 200" width="220" height="220" style="overflow:visible;touch-action:none;display:block;margin:0 auto"></svg>
                </div>
              </div>
              <!-- Harvard Plate info panel (toggles on ℹ️ click) -->
              <div class="plate-info-panel hidden" id="plate-info-panel">
                <p class="plate-info-title">📚 About the Harvard Plate</p>
                <div class="plate-info-row">
                  <span class="plate-info-icon">🥦</span>
                  <div>
                    <div class="plate-info-row-label">Veggies &amp; Fruits (50%)</div>
                    <p class="plate-info-row-text">Fill half your plate with color. Keeps you full, rich in nutrients.</p>
                    <p class="plate-info-tip">Tip: Vegetables &gt; fruits where possible.</p>
                  </div>
                </div>
                <div class="plate-info-row">
                  <span class="plate-info-icon">🍚</span>
                  <div>
                    <div class="plate-info-row-label">Grains &amp; Carbs (25%)</div>
                    <p class="plate-info-row-text">Choose whole grains when you can. Brown rice, oats, whole wheat pasta.</p>
                    <p class="plate-info-tip">Refined carbs like white bread are okay occasionally.</p>
                  </div>
                </div>
                <div class="plate-info-row">
                  <span class="plate-info-icon">🍗</span>
                  <div>
                    <div class="plate-info-row-label">Protein (25%)</div>
                    <p class="plate-info-row-text">Fish, chicken, beans, eggs, tofu, nuts.</p>
                    <p class="plate-info-tip">Try to vary your protein sources.</p>
                  </div>
                </div>
                <div class="plate-info-row" style="border-bottom:none">
                  <span class="plate-info-icon">💧</span>
                  <div>
                    <div class="plate-info-row-label">Don't forget water</div>
                    <p class="plate-info-row-text">Drink water with your meals. Avoid sugary drinks.</p>
                  </div>
                </div>
                <div class="plate-info-footer">
                  <p class="plate-info-credit">Based on Harvard Healthy Eating Plate<br>Developed by Harvard T.H. Chan School of Public Health</p>
                  <a href="https://nutritionsource.hsph.harvard.edu/healthy-eating-plate/" target="_blank" rel="noopener noreferrer" class="plate-info-link">Learn more at Harvard.edu ↗</a>
                </div>
              </div>
              <div id="plate-section-labels" class="plate-section-labels"></div>
              <!-- Removed sections re-add pills -->
              <div id="removed-sections-area" class="removed-sections-area"></div>
              <!-- Inline remove confirmation -->
              <div id="remove-confirm-area" class="remove-confirm-area"></div>
              <!-- Verdict confirm area — populated by renderVerdictUI() -->
              <div class="plate-verdict-row" id="plate-verdict-row"></div>
              <input type="text" class="form-input" id="plate-note" placeholder="What did you have? (optional)" maxlength="200" style="margin-top:var(--space-md)" />
              <!-- Hidden until verdict confirmed -->
              <button class="btn-accent hidden" style="width:100%;margin-top:var(--space-sm)" id="log-plate-btn">Log this plate</button>
            </div>
          </div>

          <!-- Simple secondary grid -->
          <div class="simple-secondary-grid">
            <div class="simple-main-col">

              <div class="card-lg" id="flex-plates-card">
                <h2 class="col-heading" style="margin-bottom:var(--space-md)">Flex Plates</h2>
                <div id="flex-plates-content"></div>
              </div>

              <div class="card-lg" id="habits-card">
                <h2 class="col-heading" style="margin-bottom:var(--space-md)">Daily Habits</h2>
                <div id="habits-content"></div>
              </div>

              <div class="card-lg" id="checklist-card">
                <h2 class="col-heading" style="margin-bottom:var(--space-md)">Daily Checklist</h2>
                <div id="checklist-content"></div>
              </div>

              <div class="card-lg hidden" id="weight-card">
                <h2 class="col-heading" style="margin-bottom:var(--space-md)">Weekly Weight</h2>
                <div id="weight-content"></div>
              </div>

            </div>

            <aside class="badges-col" aria-label="Achievement badges">
              <h2 class="col-heading">Badges</h2>
              <div class="badges-grid" id="badges-grid-simple"></div>
              <a href="/streaks" class="badge-more-link">
                View streaks &amp; share
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
              </a>
            </aside>
          </div>
        </div>

        <!-- ═══ DETAILED DASHBOARD ═══ -->
        <div id="detailed-dashboard" class="hidden">

          <section class="calories-card card-lg" aria-label="Calories summary">
            <h2 class="eyebrow" style="margin-bottom:var(--space-md)">Today's calories</h2>
            <div class="calories-numbers">
              <div class="cal-block cal-block-main">
                <span id="cal-consumed" class="cal-num">0</span>
                <span class="cal-label">consumed</span>
              </div>
              <div class="cal-divider" aria-hidden="true">/</div>
              <div class="cal-block">
                <span id="cal-goal" class="cal-num cal-num-muted">—</span>
                <span class="cal-label">goal</span>
              </div>
              <div class="cal-remaining-block">
                <span id="cal-remaining" class="cal-remaining-num">—</span>
                <span class="cal-label">remaining</span>
              </div>
            </div>
            <div class="progress-bar" style="margin-top:var(--space-md)" role="progressbar" id="cal-progress" aria-valuemin="0" aria-valuemax="100">
              <div class="progress-fill" id="progress-fill" style="width:0%"></div>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-top:var(--space-xs)">
              <span id="cal-percent-text" class="cal-percent-text">0% of goal</span>
            </div>
            <div id="macro-totals" class="macro-totals hidden">
              <div class="divider" style="margin:var(--space-md) 0 var(--space-sm)"></div>
              <p class="eyebrow" style="margin-bottom:var(--space-sm)">Macros today</p>
              <div class="macro-row">
                <div class="macro-item"><span class="macro-label">Protein</span><span id="total-protein" class="macro-val">0g</span></div>
                <div class="macro-item"><span class="macro-label">Carbs</span><span id="total-carbs" class="macro-val">0g</span></div>
                <div class="macro-item"><span class="macro-label">Fats</span><span id="total-fats" class="macro-val">0g</span></div>
              </div>
            </div>
          </section>

          <div class="dashboard-grid">
            <div class="meal-col">
              <div id="meal-sections-root"></div>
            </div>
            <aside class="badges-col" aria-label="Achievement badges">
              <h2 class="col-heading">Badges</h2>
              <div class="badges-grid" id="badges-grid-detailed"></div>
              <a href="/streaks" class="badge-more-link">
                View streaks &amp; share
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
              </a>
            </aside>
          </div>
        </div>

      </div>
    </div>

    <!-- Harvard Plate First-Time Education Modal -->
    <div class="plate-edu-overlay hidden" id="plate-edu-overlay" role="dialog" aria-modal="true" aria-labelledby="plate-edu-title">
      <div class="plate-edu-modal">
        <div class="plate-edu-inner">
          <div class="plate-edu-emoji" aria-hidden="true">🍽️</div>
          <h2 class="plate-edu-title" id="plate-edu-title">Meet the Harvard Plate Method</h2>
          <p class="plate-edu-sub">Scientists at Harvard found the simplest way to eat healthy — no counting needed.</p>
          <div class="plate-edu-sections">
            <div class="plate-edu-row">
              <span class="plate-edu-icon">🥦</span>
              <div>
                <div class="plate-edu-row-title">Half your plate</div>
                <div class="plate-edu-row-sub">Veggies &amp; Fruits — Fill with color and variety</div>
              </div>
            </div>
            <div class="plate-edu-row">
              <span class="plate-edu-icon">🍚</span>
              <div>
                <div class="plate-edu-row-title">Quarter plate</div>
                <div class="plate-edu-row-sub">Whole Grains — Brown rice, oats, whole wheat</div>
              </div>
            </div>
            <div class="plate-edu-row">
              <span class="plate-edu-icon">🍗</span>
              <div>
                <div class="plate-edu-row-title">Quarter plate</div>
                <div class="plate-edu-row-sub">Protein — Fish, chicken, beans, eggs, tofu</div>
              </div>
            </div>
          </div>
          <p class="plate-edu-note">No calorie counting. Just balance.<br>Used by millions worldwide.</p>
          <button class="btn-accent plate-edu-cta" id="plate-edu-cta">Got it, let's log! →</button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .dashboard-page { padding: var(--space-xl) 0 var(--space-5xl); }

  /* No-setup state */
  .no-tdee-state { display: flex; align-items: center; justify-content: center; min-height: 60vh; }
  .no-tdee-card { text-align: center; max-width: 480px; width: 100%; margin: 0 auto; display: flex; flex-direction: column; align-items: center; }
  .no-tdee-icon { font-size: 48px; }

  /* Top row */
  .dashboard-top-row { display: flex; align-items: center; justify-content: space-between; gap: var(--space-md); margin-bottom: var(--space-lg); flex-wrap: wrap; }
  .date-mode-row { display: flex; align-items: center; gap: var(--space-sm); flex-wrap: wrap; }
  .today-date { font-size: 24px; font-weight: 600; letter-spacing: -0.6px; color: var(--color-ink); }
  .mode-badge { font-size: 12px; font-family: var(--font-mono); padding: 3px 8px; border-radius: var(--radius-full); background: var(--color-accent-soft); color: var(--color-accent-text); border: 1px solid transparent; white-space: nowrap; }
  .goal-label { font-size: 13px; color: var(--color-mute); font-family: var(--font-mono); margin-top: 2px; }
  .status-indicator { font-size: 14px; margin-top: var(--space-xxs); font-weight: 500; }
  .streak-mini { display: flex; align-items: center; gap: var(--space-sm); padding: var(--space-sm) var(--space-md); flex-shrink: 0; text-decoration: none; transition: box-shadow 0.2s; }
  .streak-mini:hover { box-shadow: var(--shadow-4); }
  .streak-fire { font-size: 24px; }
  .streak-mini-text { display: flex; flex-direction: column; line-height: 1.2; }
  .mini-streak-count { font-size: 20px; font-weight: 700; letter-spacing: -0.5px; color: var(--color-ink); }
  .mini-streak-label { font-size: 12px; color: var(--color-mute); }

  /* Calories card (detailed mode) */
  .calories-card { margin-bottom: var(--space-lg); }
  .calories-numbers { display: flex; align-items: baseline; gap: var(--space-md); flex-wrap: wrap; }
  .cal-block { display: flex; flex-direction: column; }
  .cal-num { font-size: 40px; font-weight: 700; letter-spacing: -2px; line-height: 1; color: var(--color-ink); }
  .cal-num-muted { color: var(--color-mute); }
  .cal-block-main .cal-num { color: var(--color-accent-deep); }
  .cal-divider { font-size: 32px; color: var(--color-hairline-strong); font-weight: 300; }
  .cal-label { font-size: 12px; color: var(--color-mute); font-family: var(--font-mono); text-transform: uppercase; margin-top: var(--space-xxs); }
  .cal-remaining-block { margin-left: auto; text-align: right; }
  .cal-remaining-num { font-size: 28px; font-weight: 700; letter-spacing: -1px; color: var(--color-ink); }
  .cal-percent-text { font-size: 12px; color: var(--color-mute); font-family: var(--font-mono); }
  .macro-row { display: flex; gap: var(--space-lg); flex-wrap: wrap; }
  .macro-item { display: flex; flex-direction: column; gap: 2px; }
  .macro-label { font-size: 11px; color: var(--color-mute); font-family: var(--font-mono); text-transform: uppercase; }
  .macro-val { font-size: 16px; font-weight: 600; color: var(--color-ink); }

  /* Dashboard grid (detailed mode) */
  .dashboard-grid { display: grid; grid-template-columns: 1fr 260px; gap: var(--space-lg); align-items: start; }
  .meal-col { display: flex; flex-direction: column; gap: var(--space-sm); }

  /* Badges */
  .badges-col { display: flex; flex-direction: column; gap: var(--space-md); }
  .col-heading { font-size: 16px; font-weight: 600; color: var(--color-ink); }
  .badges-grid { display: flex; flex-direction: column; gap: var(--space-sm); }
  .badge-item { display: flex; align-items: center; gap: var(--space-sm); padding: var(--space-sm) var(--space-md); border-radius: var(--radius-md); border: 1px solid var(--color-hairline); background: var(--color-canvas); }
  .badge-item.earned { border-color: var(--color-accent); background: var(--color-accent-soft); }
  .badge-item.locked { opacity: 0.45; filter: grayscale(1); }
  .badge-emoji { font-size: 22px; }
  .badge-info { flex: 1; }
  .badge-name { font-size: 13px; font-weight: 600; color: var(--color-ink); }
  .badge-req { font-size: 11px; color: var(--color-mute); font-family: var(--font-mono); }
  .badge-more-link { display: inline-flex; align-items: center; gap: var(--space-xxs); font-size: 13px; color: var(--color-accent-deep); font-weight: 500; transition: gap 0.2s; }
  .badge-more-link:hover { gap: var(--space-xs); }

  /* ── SIMPLE MODE ── */
  .plates-card { margin-bottom: var(--space-md); }
  .plates-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-lg); flex-wrap: wrap; gap: var(--space-sm); }
  .day-verdict-badge { font-size: 14px; font-weight: 600; padding: 4px 12px; border-radius: var(--radius-full); background: var(--color-canvas-soft-2); color: var(--color-ink); border: 1px solid var(--color-hairline); }
  .day-verdict-badge.verdict-great { background: #d1fae5; color: #065f46; border-color: #6ee7b7; }
  .day-verdict-badge.verdict-good { background: #fef3c7; color: #92400e; border-color: #fcd34d; }
  .day-verdict-badge.verdict-keep { background: #dbeafe; color: #1e40af; border-color: #93c5fd; }

  .plates-slots { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-md); }
  .plate-slot { border: 1px solid var(--color-hairline); border-radius: var(--radius-lg); padding: var(--space-md); display: flex; flex-direction: column; gap: var(--space-sm); min-height: 120px; }
  .plate-slot-label { font-size: 13px; font-weight: 600; color: var(--color-ink); }
  .plate-slot-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; }
  .plate-slot-logged { display: flex; flex-direction: column; gap: var(--space-xs); }
  .plate-slot-verdict { font-size: 13px; font-weight: 600; }
  .plate-slot-verdict.treat { color: #1d4ed8; }
  .plate-slot-verdict.healthy { color: #065f46; }
  .plate-slot-sections { font-size: 11px; color: var(--color-mute); font-family: var(--font-mono); line-height: 1.6; }
  .plate-slot-note { font-size: 12px; color: var(--color-body); font-style: italic; }
  .plate-slot-actions { display: flex; gap: var(--space-xs); margin-top: var(--space-xs); }
  .plate-action-btn { font-size: 12px; padding: 3px 10px; border-radius: var(--radius-xs); border: 1px solid var(--color-hairline); background: var(--color-canvas); color: var(--color-body); cursor: pointer; transition: all 0.15s; font-family: inherit; }
  .plate-action-btn:hover { background: var(--color-canvas-soft-2); }
  .plate-action-btn.danger:hover { background: var(--color-error-soft); color: var(--color-error); border-color: var(--color-error); }

  /* Plate circle logger */
  .plate-logger-panel { padding-top: var(--space-sm); }
  .plate-logger-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-lg); }
  .plate-circle-wrap { display: flex; justify-content: center; margin-bottom: var(--space-md); }
  .plate-circle-container { border-radius: 50%; transition: box-shadow 0.3s; padding: 8px; }
  .plate-circle-container.glow-healthy { box-shadow: 0 0 24px rgba(16,185,129,0.5), 0 0 48px rgba(16,185,129,0.2); }
  .plate-circle-container.glow-treat { box-shadow: 0 0 24px rgba(249,115,22,0.5), 0 0 48px rgba(249,115,22,0.2); }
  #plate-svg .ph { touch-action: none; cursor: grab; }
  @media (max-width: 768px) {
    #plate-svg .pv { r: 13; }
  }

  .plate-section-labels { display: flex; flex-direction: column; gap: var(--space-xs); margin-bottom: var(--space-xs); }
  .sl-row { display: flex; align-items: center; justify-content: space-between; font-size: 13px; }
  .sl-name { color: var(--color-body); }
  .sl-pct { font-weight: 600; font-family: var(--font-mono); }
  .sl-remove-btn {
    width: 18px; height: 18px; border-radius: 50%; border: 1px solid var(--color-hairline);
    background: var(--color-canvas-soft); color: var(--color-mute); cursor: pointer;
    font-size: 13px; line-height: 18px; text-align: center; display: inline-flex;
    align-items: center; justify-content: center; transition: all 0.15s; padding: 0; font-family: inherit;
    flex-shrink: 0;
  }
  .sl-remove-btn:hover { background: var(--color-error-soft); border-color: var(--color-error); color: var(--color-error); }

  /* Removed section pills */
  .removed-sections-area { display: flex; flex-wrap: wrap; gap: var(--space-xs); margin-top: var(--space-xs); margin-bottom: var(--space-sm); min-height: 0; }
  .removed-pill {
    font-size: 12px; padding: 3px 10px; border-radius: var(--radius-pill);
    border: 1px dashed var(--color-hairline); background: var(--color-canvas-soft);
    color: var(--color-mute); cursor: pointer; transition: all 0.15s; font-family: inherit;
  }
  .removed-pill:hover { border-color: var(--color-accent); color: var(--color-accent-deep); background: var(--color-accent-soft); border-style: solid; }

  /* Remove confirm box */
  .remove-confirm-area { margin-bottom: var(--space-sm); }
  .remove-confirm-box { background: var(--color-canvas-soft-2); border: 1px solid var(--color-hairline); border-radius: var(--radius-md); padding: var(--space-sm) var(--space-md); font-size: 13px; color: var(--color-body); display: flex; align-items: center; gap: var(--space-sm); flex-wrap: wrap; }
  .remove-confirm-label { flex: 1; font-weight: 500; }

  /* Verdict confirm UI */
  .plate-verdict-row { margin-bottom: var(--space-sm); }
  .verdict-suggest { font-size: 14px; color: var(--color-body); margin-bottom: var(--space-sm); text-align: center; line-height: 1.5; }
  .verdict-confirm-btns { display: flex; gap: var(--space-sm); justify-content: center; flex-wrap: wrap; }
  .verdict-confirmed-row { display: flex; align-items: center; justify-content: center; gap: var(--space-md); padding: var(--space-sm) 0; }
  .verdict-confirmed-label { font-size: 16px; font-weight: 600; color: var(--color-ink); }

  /* Flex plates status */
  .flex-status { font-size: 13px; font-weight: 500; padding: 3px 12px; border-radius: var(--radius-full); display: inline-block; margin-top: var(--space-xs); }
  .flex-status-green { background: #d1fae5; color: #065f46; }
  .flex-status-yellow { background: #fef3c7; color: #92400e; }
  .flex-status-red { background: #fee2e2; color: #991b1b; }

  /* Simple secondary grid */
  .simple-secondary-grid { display: grid; grid-template-columns: 1fr 260px; gap: var(--space-lg); align-items: start; margin-top: var(--space-md); }
  .simple-main-col { display: flex; flex-direction: column; gap: var(--space-md); }

  /* Habits card */
  .habit-group { display: flex; flex-direction: column; gap: var(--space-xs); padding: var(--space-sm) 0; border-bottom: 1px solid var(--color-hairline); }
  .habit-group:last-child { border-bottom: none; padding-bottom: 0; }
  .habit-group-label { font-size: 13px; font-weight: 500; color: var(--color-ink); }
  .habit-btn-row { display: flex; flex-wrap: wrap; gap: var(--space-xxs); }
  .habit-pill {
