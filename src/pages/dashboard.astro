  .plate-info-btn { width: 28px; height: 28px; border-radius: var(--radius-full); border: 1px solid var(--color-hairline); background: var(--color-canvas-soft); color: var(--color-mute); cursor: pointer; font-size: 15px; display: flex; align-items: center; justify-content: center; transition: all 0.15s; padding: 0; font-family: inherit; flex-shrink: 0; }
  .plate-info-btn:hover { background: var(--color-accent-soft); border-color: var(--color-accent); }

  /* Harvard info panel */
  .plate-info-panel { background: var(--color-canvas-soft); border: 1px solid var(--color-hairline); border-radius: var(--radius-md); padding: var(--space-md); margin: var(--space-sm) 0 var(--space-xs); }
  .plate-info-title { font-size: 13px; font-weight: 700; color: var(--color-ink); margin-bottom: var(--space-sm); }
  .plate-info-row { display: flex; gap: var(--space-sm); padding: var(--space-xs) 0; border-bottom: 1px solid var(--color-hairline); }
  .plate-info-icon { font-size: 18px; flex-shrink: 0; line-height: 1.5; }
